    "\n",
    "ubicacion_datos_consolidados_janis = r\"C:\\Users\\usuario1\\OneDrive - Universidad de Antioquia\\UNIVERSIDAD DE ANTIOQUIA\\Proyecto SAT Dengue\\Bases de datos\\Datos consolidados\"\n",
    "\n",
    "# =========================================================\n",
    "# CREACIÓN DE REZAGOS ACUMULADOS\n",
    "# =========================================================\n",
    "\n",
    "# Humedad específica → lag 1-8\n",
    "df_procesados['hum_esp_mean_lag1_8'] = np.mean(\n",
    "    [df_procesados['hum_esp_bc'].shift(i) for i in range(1,9)],\n",
    "    axis=0\n",
    ")\n",
    "\n",
    "# Temperatura máxima → lag 1-6\n",
    "df_procesados['temp_max_mean_lag1_6'] = np.mean(\n",
    "    [df_procesados['temp_max_bc'].shift(i) for i in range(1,7)],\n",
    "    axis=0\n",
    ")\n",
    "\n",
    "# Días de lluvia → lag 3-8\n",
    "df_procesados['dias_lluvia_mean_lag3_8'] = np.mean(\n",
    "    [df_procesados['dias_lluvia_ln'].shift(i) for i in range(3,9)],\n",
    "    axis=0\n",
    ")\n",
    "\n",
    "# Velocidad máxima del viento → lag 1-6\n",
    "df_procesados['vel_vi_max_mean_lag1_6'] = np.mean(\n",
    "    [df_procesados['vel_vi_max_bc'].shift(i) for i in range(1,7)],\n",
    "    axis=0\n",
    ")\n",
    "\n",
    "# SST → lag 8-12\n",
    "df_procesados['sst_mean_lag8_12'] = np.mean(\n",
    "    [df_procesados['sst_yj'].shift(i) for i in range(8,13)],\n",
    "    axis=0\n",
    ")\n",
    "\n",
    "# =========================================================\n",
